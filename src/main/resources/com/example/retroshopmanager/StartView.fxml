            </padding>
            <children>
                <Label style="-fx-text-fill: #13253a; -fx-font-size: 28; -fx-font-weight: bold;" text="RetroWypożyczalnia" />
                <Label maxWidth="680.0" wrapText="true" style="-fx-text-fill: #53647a; -fx-font-size: 14;" text="Aplikacja dla pracowników wypożyczalni fizycznych nośników. System pomaga zarządzać asortymentem, bazą klientów oraz dziennikiem wypożyczeń w jednym miejscu." />
            </children>
        </VBox>
        <GridPane hgap="14.0" vgap="14.0">
            <children>
                <VBox minHeight="155.0" prefHeight="155.0" prefWidth="220.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dce3ee; -fx-border-radius: 8;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #4f61d8; -fx-font-size: 22; -fx-font-weight: bold;" text="01" />
                        <Label style="-fx-text-fill: #13253a; -fx-font-size: 15; -fx-font-weight: bold;" text="Wybierz moduł" />
                        <Label maxWidth="1.7976931348623157E308" wrapText="true" style="-fx-text-fill: #66758a; -fx-font-size: 12;" text="Otwórz wybrany moduł z menu po lewej stronie." />
                    </children>
                </VBox>
                <VBox minHeight="155.0" prefHeight="155.0" prefWidth="220.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dce3ee; -fx-border-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #1b7f5f; -fx-font-size: 22; -fx-font-weight: bold;" text="02" />
                        <Label style="-fx-text-fill: #13253a; -fx-font-size: 15; -fx-font-weight: bold;" text="Zarządzaj danymi" />
                        <Label maxWidth="1.7976931348623157E308" wrapText="true" style="-fx-text-fill: #66758a; -fx-font-size: 12;" text="Dodawaj, edytuj i usuwaj dane zapisane w bazie SQLite." />
                    </children>
                </VBox>
                <VBox minHeight="155.0" prefHeight="155.0" prefWidth="220.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dce3ee; -fx-border-radius: 8;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <padding>
