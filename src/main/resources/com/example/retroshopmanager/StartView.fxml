                    </padding>
                    <children>
                        <Label style="-fx-text-fill: #c18418; -fx-font-size: 22; -fx-font-weight: bold;" text="03" />
                        <Label style="-fx-text-fill: #13253a; -fx-font-size: 15; -fx-font-weight: bold;" text="Obsługuj wypożyczenia" />
