<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="650.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.retroshopmanager.MusicController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleAddAction" prefWidth="80.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Dodaj" />
                <Button mnemonicParsing="false" onAction="#handleEditAction" prefWidth="80.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Edytuj" />
                <Button mnemonicParsing="false" onAction="#handleDeleteAction" prefWidth="80.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Usuń" />
            </children>
        </HBox>
        <TableView fx:id="musicTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="titleColumn" prefWidth="250.0" text="Tytuł Płyty" />
                <TableColumn fx:id="artistColumn" prefWidth="200.0" text="Wykonawca" />
                <TableColumn fx:id="yearColumn" prefWidth="100.0" text="Rok Wydania" />
            </columns>
        </TableView>
    </children>
</VBox>