<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1120.0" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.retroshopmanager.MainController">
    <left>
        <VBox prefWidth="215.0" spacing="16.0" style="-fx-background-color: linear-gradient(to bottom, #061a2d, #08243b);" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="22.0" left="12.0" right="12.0" top="28.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label alignment="CENTER" prefHeight="44.0" prefWidth="44.0" style="-fx-background-color: #1f3855; -fx-background-radius: 22; -fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="RW" />
                        <VBox spacing="2.0">
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="RetroWypożyczalnia" />
                                <Label style="-fx-text-fill: #c9d7e8; -fx-font-size: 12;" text="Panel pracownika" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <Separator opacity="0.18" />
                <Button mnemonicParsing="false" onAction="#showStartView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: rgba(79, 97, 216, 0.35); -fx-background-radius: 7; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Start" />
                <Button mnemonicParsing="false" onAction="#showMusicView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: transparent; -fx-text-fill: #e9f1fb; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Muzyka (winyle)" />
                <Button mnemonicParsing="false" onAction="#showMoviesView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: transparent; -fx-text-fill: #e9f1fb; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Filmy (CD / DVD)" />
                <Button mnemonicParsing="false" onAction="#showBooksView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: transparent; -fx-text-fill: #e9f1fb; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Książki" />
                <Button mnemonicParsing="false" onAction="#showCustomersView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: transparent; -fx-text-fill: #e9f1fb; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Klienci" />
                <Button mnemonicParsing="false" onAction="#showRentalsView" prefHeight="42.0" prefWidth="191.0" style="-fx-background-color: transparent; -fx-text-fill: #e9f1fb; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 18; -fx-cursor: hand;" text="Dziennik wypożyczeń" />
                <Region VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </left>
    <center>
        <BorderPane fx:id="mainBorderPane" style="-fx-background-color: #f5f7fb;" />
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="30.0" style="-fx-background-color: white; -fx-border-color: #dce3ee transparent transparent transparent;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="18.0" right="18.0" />
            </padding>
            <children>
                <Label style="-fx-text-fill: #7a8799; -fx-font-size: 11;" text="Aplikacja gotowa do pracy." />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: #7a8799; -fx-font-size: 11;" text="RetroWypożyczalnia" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
