<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainBorderPane" prefHeight="620.0" prefWidth="930.0" style="-fx-background-color: #f5f7fb;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.retroshopmanager.MainController">
    <left>
        <VBox prefHeight="620.0" prefWidth="190.0" spacing="14.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="24.0" />
            </padding>
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="RetroWypożyczalnia" />
                <Label style="-fx-text-fill: #d7e1ea; -fx-font-size: 12;" text="Panel pracownika" />
                <Separator opacity="0.25" />
                <Button mnemonicParsing="false" onAction="#showStartView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Start" />
                <Button mnemonicParsing="false" onAction="#showMusicView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Muzyka" />
                <Button mnemonicParsing="false" onAction="#showMoviesView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Filmy" />
                <Button mnemonicParsing="false" onAction="#showBooksView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Książki" />
                <Button mnemonicParsing="false" onAction="#showCustomersView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Klienci" />
                <Button mnemonicParsing="false" onAction="#showRentalsView" prefHeight="35.0" prefWidth="170.0" style="-fx-cursor: hand;" text="Dziennik wypożyczeń" />
                <Region VBox.vgrow="ALWAYS" />
                <Separator opacity="0.25" />
                <Label style="-fx-text-fill: #d7e1ea; -fx-font-size: 11;" text="Baza danych: SQLite" />
            </children>
        </VBox>
    </left>
</BorderPane>
