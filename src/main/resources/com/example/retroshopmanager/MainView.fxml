<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainBorderPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.retroshopmanager.MainController">
    <left>
        <VBox prefHeight="600.0" prefWidth="150.0" spacing="15.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <Button mnemonicParsing="false" onAction="#showMusicView" prefHeight="35.0" prefWidth="130.0" style="-fx-cursor: hand;" text="Muzyka" />
                <Button disable="true" mnemonicParsing="false" prefHeight="35.0" prefWidth="130.0" text="Filmy" />
                <Button disable="true" mnemonicParsing="false" prefHeight="35.0" prefWidth="130.0" text="Książki" />
            </children>
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="30.0" />
            </padding>
        </VBox>
    </left>
</BorderPane>