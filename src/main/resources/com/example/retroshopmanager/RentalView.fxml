<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="730.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.retroshopmanager.RentalController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleRentAction" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="Wypożycz" />
                <Button mnemonicParsing="false" onAction="#handleReturnAction" prefWidth="120.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-cursor: hand;" text="Zwrot" />
                <Button mnemonicParsing="false" onAction="#handleRefreshAction" prefWidth="120.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-cursor: hand;" text="Odśwież" />
            </children>
        </HBox>
        <TableView fx:id="rentalTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="45.0" text="ID" />
                <TableColumn fx:id="customerColumn" prefWidth="130.0" text="Klient" />
                <TableColumn fx:id="typeColumn" prefWidth="80.0" text="Typ" />
                <TableColumn fx:id="titleColumn" prefWidth="150.0" text="Tytuł" />
                <TableColumn fx:id="rentalDateColumn" prefWidth="100.0" text="Wypożyczono" />
                <TableColumn fx:id="dueDateColumn" prefWidth="100.0" text="Termin" />
                <TableColumn fx:id="returnDateColumn" prefWidth="100.0" text="Zwrot" />
                <TableColumn fx:id="penaltyColumn" prefWidth="70.0" text="Kara" />
                <TableColumn fx:id="statusColumn" prefWidth="90.0" text="Status" />
            </columns>
        </TableView>
    </children>
</VBox>
